---
import '../style.css';
import changelogData from '../data/changelog.json';

const typeLabels = {
  major: 'Major Release',
  feature: 'Fitur Baru',
  improvement: 'Peningkatan',
  fix: 'Perbaikan',
  security: 'Keamanan'
};

const typeColors = {
  major: '#10b981',
  feature: '#6366f1',
  improvement: '#f59e0b',
  fix: '#ef4444',
  security: '#8b5cf6'
};

const typeIcons = {
  major: '🚀',
  feature: '✨',
  improvement: '⚡',
  fix: '🔧',
  security: '🔒'
};

// Format version display: "1.0.0" -> "v1.0.0", "site-2.0" -> "Site v2.0"
function formatVersion(v) {
  if (v.startsWith('site-')) return `Site v${v.replace('site-', '')}`;
  return `v${v}`;
}

// Get category label
function getCategory(v) {
  if (v.startsWith('site-')) return 'Website';
  return 'Android App';
}

// Get category color
function getCategoryColor(v) {
  if (v.startsWith('site-')) return '#3b82f6';
  return '#22c55e';
}

// Get unique types for filter buttons
const activeTypes = [...new Set(changelogData.map(e => e.type))];
---

<!doctype html>
<html lang="id" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Changelog — SteerIn</title>
  <meta name="description" content="Lihat update, fitur baru, dan perbaikan terbaru di SteerIn.">
  <meta property="og:title" content="Changelog — SteerIn">
  <meta property="og:description" content="Lihat update, fitur baru, dan perbaikan terbaru di SteerIn.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://steerin.app/changelog">
  <meta property="og:image" content="https://steerin.app/logo.png">
  <link rel="canonical" href="https://steerin.app/changelog">
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <a href="#main" class="skip-link">Lewati ke konten utama</a>
  <div class="noise"></div>
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>

  <div class="container" id="main">
    <!-- NAVBAR -->
    <nav>
      <a href="/" class="nav-brand">
        <img src="logo.png" alt="SteerIn" class="nav-logo">
        SteerIn
      </a>
      <div class="nav-links">
        <a href="/#features">Fitur</a>
        <a href="/#faq">FAQ</a>
        <a href="/changelog" class="nav-changelog active">Changelog</a>
        <a href="/#download" class="nav-cta">Download</a>
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <!-- CHANGELOG HEADER -->
    <section class="changelog-hero">
      <div class="changelog-hero-content">
        <a href="/" class="changelog-back">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Kembali ke Beranda
        </a>
        <h1>Changelog</h1>
        <p>Riwayat update, fitur baru, dan perbaikan di SteerIn.<br>Biar kamu tahu apa yang berubah.</p>
      </div>
    </section>

    <!-- FILTERS -->
    <div class="changelog-filters">
      <button class="changelog-filter-btn active" data-filter="all">
        Semua
      </button>
      {activeTypes.map(type => (
        <button class="changelog-filter-btn" data-filter={type}>
          <span>{typeIcons[type]}</span>
          {typeLabels[type]}
        </button>
      ))}
    </div>

    <!-- CHANGELOG TIMELINE -->
    <section class="changelog-timeline">
      {changelogData.map((entry, index) => (
        <article class={`changelog-entry fade-up ${index === 0 ? 'changelog-entry--latest' : ''}`} data-type={entry.type}>
          <div class="changelog-entry-header">
            <span class="changelog-category" style={`--cat-color: ${getCategoryColor(entry.version)}`}>
              {getCategory(entry.version)}
            </span>
            <div class="changelog-version-badge" style={`--badge-color: ${typeColors[entry.type]}`}>
              <span class="changelog-version">{formatVersion(entry.version)}</span>
              <span class="changelog-type">{typeLabels[entry.type]}</span>
            </div>
            <time class="changelog-date" datetime={entry.date}>
              {new Date(entry.date).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            {index === 0 && <span class="changelog-new-badge">Baru</span>}
          </div>
          <div class="changelog-entry-body">
            <h2 class="changelog-title">{entry.title}</h2>
            <p class="changelog-description">{entry.description}</p>
            <ul class="changelog-changes">
              {entry.changes.map(change => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                  {change}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </section>

    <!-- SUBSCRIBE CTA -->
    <section class="changelog-cta fade-up">
      <div class="changelog-cta-card">
        <h3>Ingin tahu update terbaru?</h3>
        <p>Ikut early access dan dapatkan notifikasi saat ada fitur baru atau perbaikan penting.</p>
        <a href="/#download" class="btn btn--primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><use href="#i-download"/></svg>
          Ikut Early Access
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-brand">
            <img src="logo.png" alt="SteerIn" class="nav-logo">
            SteerIn
          </a>
          <p>Garasi digital privat untuk mobil dan motor. Dibuat untuk Android dengan local-first storage, cloud sync opsional, dan tanpa tracker.</p>
        </div>
        <div class="footer-col">
          <h5>Produk</h5>
          <a href="/#features">Fitur</a>
          <a href="/#how-it-works">Cara Kerja</a>
          <a href="/#download">Download</a>
          <a href="/#faq">FAQ</a>
          <a href="/changelog">Changelog</a>
        </div>
        <div class="footer-col">
          <h5>Legal</h5>
          <a href="/privacy-policy/">Privacy Policy</a>
          <a href="/terms/">Terms of Service</a>
        </div>
        <div class="footer-col">
          <h5>Support</h5>
          <a href="mailto:sudutkamar.co@gmail.com">Hubungi Support</a>
          <a href="mailto:sudutkamar.co@gmail.com?subject=Bug%20Report">Laporkan Bug</a>
          <a href="mailto:sudutkamar.co@gmail.com?subject=Feature%20Request">Request Fitur</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-copy">&copy; 2026 SteerIn. All rights reserved. Dibuat untuk Android.</div>
      </div>
    </footer>
  </div>

  <script>
    // Theme toggle
    const themeToggle = document.querySelector('.theme-toggle');
    const html = document.documentElement;
    
    const savedTheme = localStorage.getItem('theme') || 'dark';
    html.setAttribute('data-theme', savedTheme);
    
    themeToggle?.addEventListener('click', () => {
      const current = html.getAttribute('data-theme');
      const next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });

    // Mobile nav
    const navToggle = document.querySelector('.nav-toggle');
    const navLinks = document.querySelector('.nav-links');
    
    navToggle?.addEventListener('click', () => {
      const expanded = navToggle.getAttribute('aria-expanded') === 'true';
      navToggle.setAttribute('aria-expanded', String(!expanded));
      navToggle.classList.toggle('active');
      navLinks?.classList.toggle('active');
      document.body.style.overflow = expanded ? '' : 'hidden';
    });

    // Filter system
    const filterBtns = document.querySelectorAll('.changelog-filter-btn');
    const entries = document.querySelectorAll('.changelog-entry');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        entries.forEach((entry, i) => {
          const type = entry.dataset.type;
          const show = filter === 'all' || type === filter;
          
          if (show) {
            entry.style.display = '';
            entry.style.opacity = '0';
            entry.style.transform = 'translateY(16px)';
            setTimeout(() => {
              entry.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              entry.style.opacity = '1';
              entry.style.transform = 'translateY(0)';
            }, i * 50);
          } else {
            entry.style.display = 'none';
          }
        });
      });
    });

    // Fade-up animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Mark changelog as seen
    try {
      const latestVersion = document.querySelector('.changelog-entry--latest .changelog-version');
      if (latestVersion) {
        localStorage.setItem('steerin_changelog_seen', latestVersion.textContent.trim());
      }
    } catch {}
  </script>
</body>
</html>
