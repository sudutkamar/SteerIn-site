---
import '../style.css';
---
<!doctype html>
<html lang="id" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>SteerIn — Garasi Digital Privat untuk Mobil &amp; Motor</title>
  <meta name="description" content="SteerIn adalah aplikasi Android privat untuk mengelola mobil dan motor, pengingat servis, riwayat perawatan, trip GPS, bengkel terdekat, dan kesehatan kendaraan dengan penyimpanan local-first.">
  <meta property="og:title" content="SteerIn — Garasi Digital Privat Kamu">
  <meta property="og:description" content="Kelola mobil dan motor, pantau servis, catat perjalanan, temukan bengkel, dan lindungi data kendaraan dengan SteerIn.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://steerin.app">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="SteerIn — Garasi Digital Privat">
  <meta name="twitter:description" content="Kelola mobil dan motor, pantau servis, catat trip, dan lindungi data kendaraan secara privat dan local-first.">
  <meta property="og:image" content="https://steerin.app/logo.png">
  <link rel="canonical" href="https://steerin.app/">
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="apple-touch-icon" href="/logo.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "SteerIn",
    "operatingSystem": "Android",
    "applicationCategory": "VehicleManagementApplication",
    "description": "Private vehicle management for cars and motorcycles. Track maintenance, service history, trips, and workshops with local-first storage.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://steerin.app"
  }
  </script>
</head>
<body>
  <a href="#main" class="skip-link">Lewati ke konten utama</a>
  <div class="noise"></div>
  <div id="cursor-glow" aria-hidden="true"></div>
  <div id="three-canvas" aria-hidden="true"></div>
  <div class="orb orb--1"></div>
  <div class="orb orb--2"></div>
  <div class="orb orb--3"></div>

  <!-- SVG Sprite -->
  <svg style="display:none">
    <symbol id="i-car" viewBox="0 0 24 24"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/></symbol>
    <symbol id="i-activity" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></symbol>
    <symbol id="i-bell" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></symbol>
    <symbol id="i-clipboard" viewBox="0 0 24 24"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="16" x2="16" y2="16"/><line x1="8" y1="11" x2="8" y2="11"/><line x1="8" y1="16" x2="8" y2="16"/></symbol>
    <symbol id="i-pin" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></symbol>
    <symbol id="i-wrench" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></symbol>
    <symbol id="i-cloud" viewBox="0 0 24 24"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/></symbol>
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
    <symbol id="i-phone" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></symbol>
    <symbol id="i-lock" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></symbol>
    <symbol id="i-xcircle" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></symbol>
    <symbol id="i-globe" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></symbol>
    <symbol id="i-download" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></symbol>
  </svg>

  <div class="container" id="main">
    <!-- ===== NAVBAR ===== -->
    <nav>
      <a href="/" class="nav-brand">
        <img src="logo.png" alt="SteerIn" class="nav-logo">
        SteerIn
      </a>
      <div class="nav-links">
        <a href="#features">Fitur</a>
        <a href="#advantage">Kenapa SteerIn</a>
        <a href="#how-it-works">Cara Kerja</a>
        <a href="#privacy">Privasi</a>
        <a href="#faq">FAQ</a>
        <a href="#download" class="nav-cta">Download</a>
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          Dibuat untuk pemilik mobil & motor Indonesia
        </div>
        <h1>Ingat servis sebelum telat,<br><span class="gradient">rapikan semua riwayat kendaraan.</span></h1>
        <p>SteerIn mengubah struk servis tercecer, oli yang lupa diganti, pilihan bengkel yang serba tebak-tebakan, dan banyak kendaraan yang sulit dipantau menjadi satu garasi digital premium — privat dari awal, berguna tiap hari, siap untuk mobil, motor, dan EV.</p>
        <div class="hero-actions">
          <a href="#download" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><use href="#i-download"/></svg>
            Download APK Android
          </a>
          <a href="#advantage" class="btn btn--ghost">Lihat keunggulan</a>
        </div>

        <!-- Waitlist Form -->
        <form class="hero-form" data-form novalidate>
          <label for="hero-email" class="sr-only">Alamat email</label>
          <input type="email" id="hero-email" class="form-input" placeholder="Masukkan email kamu" required autocomplete="email" aria-label="Alamat email">
          <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">
          <button type="submit" class="btn btn--primary form-btn">Ikut Early Access</button>
          <div class="form-error"></div>
          <div class="form-success"></div>
        </form>
        <p class="form-note">Tanpa spam. Bisa berhenti kapan saja. 📬</p>

        <div class="hero-trust">
          <span>Local-first</span>
          <span class="dot"></span>
          <span>Mobil + motor + EV</span>
          <span class="dot"></span>
          <span>GPS trips</span>
          <span class="dot"></span>
          <span>Tanpa iklan/tracker</span>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="hero-visual" role="img" aria-label="SteerIn app dashboard showing vehicle garage with Honda Civic, Yamaha NMAX, and Toyota Avanza">
        <div class="phone">
          <div class="phone-punch"></div>
          <div class="phone-st-bar">
            <div class="phone-st-left"><span class="phone-st-time">9:41</span></div>
            <div class="phone-st-right">
              <div class="phone-st-signal"><span></span><span></span><span></span><span></span></div>
              <span class="phone-st-wifi">⌔</span>
              <div class="phone-st-batt">
                <div class="phone-st-batt-inner"><div class="phone-st-batt-fill"></div></div>
                <span>92%</span>
              </div>
            </div>
          </div>
          <div class="phone-app">
            <div class="ph-head">
              <span class="ph-head-text">SteerIn</span>
              <span class="ph-head-badge">Garage</span>
            </div>
            <span class="ph-sub">3 vehicles · 2 reminders</span>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--blue">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/></svg>
                  </div>
                  <div><div class="ph-name">Honda Civic</div><div class="ph-detail">Sedan · 2021 · 45,230 km</div></div>
                </div>
                <div class="ph-score ph-score--good">92%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--green" style="width:92%"></div></div>
            </div>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--red">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/></svg>
                  </div>
                  <div><div class="ph-name">Yamaha NMAX</div><div class="ph-detail">Scooter · 2023 · 12,800 km</div></div>
                </div>
                <div class="ph-score ph-score--good">87%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--green" style="width:87%"></div></div>
            </div>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--gray">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/></svg>
                  </div>
                  <div><div class="ph-name">Toyota Avanza</div><div class="ph-detail">MPV · 2019 · 78,100 km</div></div>
                </div>
                <div class="ph-score ph-score--ok">76%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--amber" style="width:76%"></div></div>
            </div>
            <div class="ph-reminder">
              <div class="ph-rem-icon"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div>
              <div class="ph-rem-text"><strong>Oil change due</strong> — Honda Civic<br>Every 5,000 km · 230 km overdue</div>
            </div>
            <div class="ph-reminder">
              <div class="ph-rem-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="ph-rem-text"><strong>Brake check</strong> — Toyota Avanza<br>Next service in 1,200 km</div>
            </div>
            <div class="ph-fab">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </div>
          </div>
          <div class="ph-nav">
            <div class="ph-nav-item active"><svg viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 0 0 1 1h3m10-11l2 2m-2-2v10a1 1 0 0 1-1 1h-3m-6 0a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1m-6 0h6"/></svg><span class="ph-nav-label">Home</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg><span class="ph-nav-label">Health</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg><span class="ph-nav-label">Trips</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span class="ph-nav-label">Nearby</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg><span class="ph-nav-label">Settings</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TRUST BAR ===== -->
    <section class="trust-bar">
      <div class="trust-grid">
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-phone"/></svg></div>
          <h4>Local-first by default</h4>
          <p>All your data stays on your device. No accounts required to use the core app.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-cloud"/></svg></div>
          <h4>Optional cloud sync</h4>
          <p>Backup to the cloud only when you choose. It is never automatic or mandatory.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-lock"/></svg></div>
          <h4>AES encrypted backups</h4>
          <p>Backups are encrypted with strong cryptography before leaving your device.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-xcircle"/></svg></div>
          <h4>Zero ads or trackers</h4>
          <p>No advertising, no analytics SDKs, no third-party tracking. Ever.</p>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM ===== -->
    <section class="problem" id="problem">
      <div class="section-header fade-up">
        <div class="section-badge">The Problem</div>
        <h2>Vehicle ownership gets messy fast.</h2>
        <p>Service notes get buried in chats. Oil changes are easy to forget. Trip history disappears. Workshop decisions are often rushed.</p>
      </div>
      <div class="problem-grid">
        <div class="problem-list">
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-clipboard"/></svg></div>
            <div class="problem-text">
              <h4>Scattered service records</h4>
              <p>Receipts, notes, and WhatsApp messages spread everywhere with no structure.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-bell"/></svg></div>
            <div class="problem-text">
              <h4>Forgotten maintenance</h4>
              <p>Oil changes, tire rotations, and brake checks are easy to miss without reminders.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-pin"/></svg></div>
            <div class="problem-text">
              <h4>Lost trip history</h4>
              <p>Routes, distances, and travel records disappear once the trip is done.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-wrench"/></svg></div>
            <div class="problem-text">
              <h4>Uncertain workshop decisions</h4>
              <p>Finding a reliable workshop nearby should not be a guessing game.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-car"/></svg></div>
            <div class="problem-text">
              <h4>Multiple vehicles, one headache</h4>
              <p>Managing two or more vehicles means double the records and double the stress.</p>
            </div>
          </div>
        </div>
        <div class="problem-right fade-up">
          <div class="problem-stat">
            <div class="problem-stat-num" data-target="3">0</div>
            <div class="problem-stat-label">vehicles per average household in Indonesia</div>
          </div>
          <div class="problem-quote">
            "SteerIn brings everything into one <strong>private, structured, and reliable</strong> vehicle hub."
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="features" id="features">
      <div class="section-header fade-up">
        <div class="section-badge">Fitur</div>
        <h2>Semua kebutuhan kendaraan,<br>dalam satu aplikasi.</h2>
        <p>Dibuat untuk komuter harian, pemilik mobil dan motor, keluarga dengan banyak kendaraan, dan siapa pun yang ingin riwayat kendaraan lengkap.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card fade-up">
          <div class="feature-icon fi-green"><svg><use href="#i-car"/></svg></div>
          <h3>Garasi Multi-Kendaraan</h3>
          <p>Kelola mobil dan motor dalam satu tempat lengkap dengan profil, kilometer, nomor polisi, dan detail kepemilikan.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-blue"><svg><use href="#i-activity"/></svg></div>
          <h3>Pantau Kesehatan Kendaraan</h3>
          <p>Deteksi potensi masalah lebih awal lewat kondisi komponen, pemakaian, dan indikator berbasis kilometer.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-purple"><svg><use href="#i-bell"/></svg></div>
          <h3>Pengingat Servis</h3>
          <p>Dapatkan pengingat sebelum oli, ban, rem, atau servis berkala lain telat dikerjakan.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-amber"><svg><use href="#i-clipboard"/></svg></div>
          <h3>Riwayat Servis</h3>
          <p>Simpan setiap perbaikan, penggantian part, dan kunjungan bengkel untuk referensi dan nilai jual kembali.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-pink"><svg><use href="#i-pin"/></svg></div>
          <h3>Catatan Trip GPS</h3>
          <p>Catat perjalanan, jarak, rute, dan riwayat mobilitas dengan data lokasi tetap dalam kontrol kamu.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-cyan"><svg><use href="#i-wrench"/></svg></div>
          <h3>Pencarian Bengkel</h3>
          <p>Temukan bengkel terdekat dan ambil keputusan lebih baik saat kendaraan butuh penanganan profesional.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-orange"><svg><use href="#i-cloud"/></svg></div>
          <h3>Cloud Sync &amp; Backup</h3>
          <p>Backup your vehicle records securely and restore them when switching devices — optional, never forced.</p>
        </div>
        <div class="feature-card fade-up">
