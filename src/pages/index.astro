---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import MobileSidebar from '../components/MobileSidebar.astro';

const mobileLinks = [
  { href: '#features', label: 'Fitur', i18n: 'nav.features', icon: 'car' },
  { href: '#download', label: 'Download', i18n: 'nav.download', icon: 'download' },
  { href: '#how-it-works', label: 'Cara Kerja', i18n: 'nav.how', icon: 'activity' },
  { href: '#privacy', label: 'Privasi', i18n: 'nav.privacy', icon: 'lock' },
  { href: '#faq', label: 'FAQ', i18n: 'nav.faq', icon: 'help' },
  { href: '/changelog', label: 'Changelog', icon: 'clipboard', class: 'nav-changelog' },
];

const navLinks = [
  { href: '#features', label: 'Fitur', i18n: 'nav.features' },
  { href: '#how-it-works', label: 'Cara Kerja', i18n: 'nav.how' },
  { href: '#privacy', label: 'Privasi', i18n: 'nav.privacy' },
  { href: '#faq', label: 'FAQ', i18n: 'nav.faq' },
  { href: '/changelog', label: 'Changelog', class: 'nav-changelog' },
];
---
<BaseLayout showCursor={true} showThree={true} orbs={3}>
  <Fragment slot="head">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "SteerIn",
    "operatingSystem": "Android",
    "applicationCategory": "VehicleManagementApplication",
    "description": "Private vehicle management for cars and motorcycles. Track maintenance, service history, trips, and workshops with local-first storage.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://steerin-site.vercel.app"
  }
  </script>
  </Fragment>

  <!-- SVG Sprite -->
  <svg style="display:none">
    <symbol id="i-car" viewBox="0 0 24 24"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/></symbol>
    <symbol id="i-activity" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></symbol>
    <symbol id="i-bell" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></symbol>
    <symbol id="i-clipboard" viewBox="0 0 24 24"><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="16" x2="16" y2="16"/><line x1="8" y1="11" x2="8" y2="11"/><line x1="8" y1="16" x2="8" y2="16"/></symbol>
    <symbol id="i-pin" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></symbol>
    <symbol id="i-wrench" viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></symbol>
    <symbol id="i-cloud" viewBox="0 0 24 24"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"/></symbol>
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
    <symbol id="i-phone" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></symbol>
    <symbol id="i-lock" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></symbol>
    <symbol id="i-xcircle" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></symbol>
    <symbol id="i-globe" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></symbol>
    <symbol id="i-download" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></symbol>
  </svg>

  <div class="container" id="main">
    <!-- ===== NAVBAR ===== -->
    <Navbar links={navLinks} ctaHref="#download" showLanguage={true} />

    <!-- ===== HERO ===== -->
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot"></span>
          <span data-i18n="hero.badge">Dibuat untuk pemilik mobil &amp; motor Indonesia</span>
        </div>
        <h1><span data-i18n="hero.h1.before">Ingat servis sebelum telat,</span><br><span class="gradient" data-i18n="hero.h1.gradient">rapikan semua riwayat kendaraan.</span></h1>
        <p data-i18n="hero.p">SteerIn membantu kamu mengelola servis, odometer, trip, bengkel, dan riwayat kendaraan dalam satu garasi digital yang rapi, privat, dan mudah dipakai.</p>
        <div class="hero-actions">
          <a href="#download" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><use href="#i-download"/></svg>
            <span data-i18n="hero.cta.download">Download APK Android</span>
          </a>
          <a href="#features" class="btn btn--ghost" data-i18n="hero.cta.advantage">Lihat fitur</a>
        </div>

        <!-- Waitlist Form -->
        <form class="hero-form" data-form novalidate>
          <label for="hero-email" class="sr-only" data-i18n="hero.form.placeholder">Alamat email</label>
          <input type="email" id="hero-email" class="form-input" placeholder="Masukkan email kamu" required autocomplete="email" aria-label="Alamat email" data-i18n-placeholder="hero.form.placeholder">
          <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">
          <button type="submit" class="btn btn--primary form-btn" data-i18n="hero.form.btn">Ikut Early Access</button>
          <div class="form-error"></div>
          <div class="form-success"></div>
        </form>
        <p class="form-note" data-i18n="hero.form.note">Tanpa spam. Bisa berhenti kapan saja. 📬</p>

        <div class="hero-trust">
          <span data-i18n="hero.trust.1">Local-first</span>
          <span class="dot"></span>
          <span data-i18n="hero.trust.2">Mobil + motor</span>
          <span class="dot"></span>
          <span data-i18n="hero.trust.3">GPS trips</span>
          <span class="dot"></span>
          <span data-i18n="hero.trust.4">Tanpa iklan/tracker</span>
        </div>
      </div>

      <!-- Phone Mockup -->
      <div class="hero-visual" role="img" aria-label="SteerIn app dashboard showing vehicle garage with Honda Civic, Yamaha NMAX, and Toyota Avanza">
        <div class="phone">
          <div class="phone-punch"></div>
          <div class="phone-st-bar">
            <div class="phone-st-left"><span class="phone-st-time">9:41</span></div>
            <div class="phone-st-right">
              <div class="phone-st-signal"><span></span><span></span><span></span><span></span></div>
              <span class="phone-st-wifi">⌔</span>
              <div class="phone-st-batt">
                <div class="phone-st-batt-inner"><div class="phone-st-batt-fill"></div></div>
                <span>92%</span>
              </div>
            </div>
          </div>
          <div class="phone-app">
            <div class="ph-head">
              <span class="ph-head-text">SteerIn</span>
              <span class="ph-head-badge">Garage</span>
            </div>
            <span class="ph-sub">3 vehicles · 2 reminders</span>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--blue">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/></svg>
                  </div>
                  <div><div class="ph-name">Honda Civic</div><div class="ph-detail">Sedan · 2021 · 45,230 km</div></div>
                </div>
                <div class="ph-score ph-score--good">92%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--green" style="width:92%"></div></div>
            </div>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--red">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/></svg>
                  </div>
                  <div><div class="ph-name">Yamaha NMAX</div><div class="ph-detail">Scooter · 2023 · 12,800 km</div></div>
                </div>
                <div class="ph-score ph-score--good">87%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--green" style="width:87%"></div></div>
            </div>
            <div class="ph-card">
              <div class="ph-card-top">
                <div class="ph-card-left">
                  <div class="ph-avatar ph-avatar--gray">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/></svg>
                  </div>
                  <div><div class="ph-name">Toyota Avanza</div><div class="ph-detail">MPV · 2019 · 78,100 km</div></div>
                </div>
                <div class="ph-score ph-score--ok">76%</div>
              </div>
              <div class="ph-bar"><div class="ph-bar-fill ph-bar-fill--amber" style="width:76%"></div></div>
            </div>
            <div class="ph-reminder">
              <div class="ph-rem-icon"><svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></div>
              <div class="ph-rem-text"><strong>Oil change due</strong> — Honda Civic<br>Every 5,000 km · 230 km overdue</div>
            </div>
            <div class="ph-reminder">
              <div class="ph-rem-icon"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
              <div class="ph-rem-text"><strong>Brake check</strong> — Toyota Avanza<br>Next service in 1,200 km</div>
            </div>
          </div>
          <div class="ph-nav">
            <div class="ph-nav-item active"><svg viewBox="0 0 24 24"><path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/></svg><span class="ph-nav-label">Garage</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 3-6.7"/><polyline points="3 3 3 9 9 9"/><path d="M12 7v5l3 2"/></svg><span class="ph-nav-label">History</span></div>
            <div class="ph-nav-item ph-nav-add"><svg viewBox="0 0 24 24"><line x1="12" y1="7" x2="12" y2="17"/><line x1="7" y1="12" x2="17" y2="12"/></svg><span class="ph-nav-label sr-only">Add</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span class="ph-nav-label">Maps</span></div>
            <div class="ph-nav-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 8.6 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 8.6a1.65 1.65 0 0 0-.33-1.82l-.06-.06A2 2 0 0 1 7.04 3.9l.06.06A1.65 1.65 0 0 0 8.6 4.6 1.65 1.65 0 0 0 10 3.09V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 8.6a1.65 1.65 0 0 0 1.51 1.4H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg><span class="ph-nav-label">Settings</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TRUST BAR ===== -->
    <section class="trust-bar">
      <div class="trust-grid">
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-phone"/></svg></div>
          <h4 data-i18n="trust.1.title">Local-first by default</h4>
          <p data-i18n="trust.1.p">Login diperlukan untuk mulai memakai app, sementara data kendaraan tetap diprioritaskan tersimpan lokal di perangkat.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-cloud"/></svg></div>
          <h4 data-i18n="trust.2.title">Cloud sync opsional</h4>
          <p data-i18n="trust.2.p">Backup ke cloud hanya saat kamu pilih. Tidak pernah otomatis atau wajib.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-lock"/></svg></div>
          <h4 data-i18n="trust.3.title">Backup terenkripsi AES</h4>
          <p data-i18n="trust.3.p">Backup dienkripsi dengan kriptografi kuat sebelum keluar dari perangkat kamu.</p>
        </div>
        <div class="trust-card fade-up">
          <div class="trust-card-icon"><svg><use href="#i-xcircle"/></svg></div>
          <h4 data-i18n="trust.4.title">Tanpa iklan atau tracker</h4>
          <p data-i18n="trust.4.p">Tanpa iklan, tanpa SDK analitik, tanpa pelacakan pihak ketiga. Selamanya.</p>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM ===== -->
    <section class="problem" id="problem">
      <div class="section-header fade-up">
        <div class="section-badge" data-i18n="problem.badge">Masalah</div>
        <h2 data-i18n="problem.h2">Kepemilikan kendaraan cepat berantakan.</h2>
        <p data-i18n="problem.p">Catatan servis tenggelam di chat. Oli mudah lupa diganti. Riwayat perjalanan hilang. Keputusan bengkel sering terburu-buru.</p>
      </div>
      <div class="problem-grid">
        <div class="problem-list">
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-clipboard"/></svg></div>
            <div class="problem-text">
              <h4 data-i18n="problem.1.title">Catatan servis tercecer</h4>
              <p data-i18n="problem.1.p">Struk, catatan, dan pesan WhatsApp tersebar tanpa struktur.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-bell"/></svg></div>
            <div class="problem-text">
              <h4 data-i18n="problem.2.title">Perawatan terlupa</h4>
              <p data-i18n="problem.2.p">Ganti oli, rotasi ban, dan cek rem mudah terlewat tanpa pengingat.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-pin"/></svg></div>
            <div class="problem-text">
              <h4 data-i18n="problem.3.title">Riwayat trip hilang</h4>
              <p data-i18n="problem.3.p">Rute, jarak, dan catatan perjalanan lenyap begitu trip selesai.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-wrench"/></svg></div>
            <div class="problem-text">
              <h4 data-i18n="problem.4.title">Keputusan bengkel tidak pasti</h4>
              <p data-i18n="problem.4.p">Menemukan bengkel terpercaya seharusnya bukan tebak-tebakan.</p>
            </div>
          </div>
          <div class="problem-item fade-up">
            <div class="problem-icon"><svg><use href="#i-car"/></svg></div>
            <div class="problem-text">
              <h4 data-i18n="problem.5.title">Banyak kendaraan, satu sakit kepala</h4>
              <p data-i18n="problem.5.p">Mengelola dua kendaraan atau lebih berarti double catatan dan double stres.</p>
            </div>
          </div>
        </div>
        <div class="problem-right fade-up">
          <div class="problem-stat">
            <div class="problem-stat-num" data-target="3">0</div>
            <div class="problem-stat-label" data-i18n="problem.stat.label">kendaraan per rumah tangga rata-rata di Indonesia</div>
          </div>
          <div class="problem-quote" data-i18n-html="problem.quote">
            "SteerIn menggabungkan semuanya dalam satu <strong>hub kendaraan yang privat, terstruktur, dan terpercaya</strong>."
          </div>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="features" id="features">
      <div class="section-header fade-up">
        <div class="section-badge" data-i18n="features.badge">Fitur</div>
        <h2 data-i18n-html="features.h2">Semua kebutuhan kendaraan,<br>dalam satu aplikasi.</h2>
        <p data-i18n="features.p">Dibuat untuk komuter harian, pemilik mobil dan motor, keluarga dengan banyak kendaraan, dan siapa pun yang ingin riwayat kendaraan lengkap.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card fade-up">
          <div class="feature-icon fi-green"><svg><use href="#i-car"/></svg></div>
          <h3 data-i18n="features.1.title">Garasi Multi-Kendaraan</h3>
          <p data-i18n="features.1.p">Kelola mobil dan motor dalam satu tempat lengkap dengan profil, kilometer, nomor polisi, dan detail kepemilikan.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-blue"><svg><use href="#i-activity"/></svg></div>
          <h3 data-i18n="features.2.title">Pantau Kesehatan Kendaraan</h3>
          <p data-i18n="features.2.p">Deteksi potensi masalah lebih awal lewat kondisi komponen, pemakaian, dan indikator berbasis kilometer.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-purple"><svg><use href="#i-bell"/></svg></div>
          <h3 data-i18n="features.3.title">Pengingat Servis</h3>
          <p data-i18n="features.3.p">Dapatkan pengingat sebelum oli, ban, rem, atau servis berkala lain telat dikerjakan.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-amber"><svg><use href="#i-clipboard"/></svg></div>
          <h3 data-i18n="features.4.title">Riwayat Servis</h3>
          <p data-i18n="features.4.p">Simpan setiap perbaikan, penggantian part, dan kunjungan bengkel untuk referensi dan nilai jual kembali.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-pink"><svg><use href="#i-pin"/></svg></div>
          <h3 data-i18n="features.5.title">Catatan Trip GPS</h3>
          <p data-i18n="features.5.p">Catat perjalanan, jarak, rute, dan riwayat mobilitas dengan data lokasi tetap dalam kontrol kamu.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-cyan"><svg><use href="#i-wrench"/></svg></div>
          <h3 data-i18n="features.6.title">Pencarian Bengkel</h3>
          <p data-i18n="features.6.p">Temukan bengkel terdekat dan ambil keputusan lebih baik saat kendaraan butuh penanganan profesional.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-orange"><svg><use href="#i-cloud"/></svg></div>
          <h3 data-i18n="features.7.title">Cloud Sync &amp; Backup</h3>
          <p data-i18n="features.7.p">Backup catatan kendaraan kamu dengan aman dan restore saat ganti perangkat — opsional, tidak pernah dipaksa.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-emerald"><svg><use href="#i-shield"/></svg></div>
          <h3 data-i18n="features.8.title">Kontrol Privasi</h3>
          <p data-i18n="features.8.p">Tanpa iklan, tanpa tracker, tanpa pengumpulan data tersembunyi. Data kendaraan tetap milik kamu.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-blue"><svg><use href="#i-activity"/></svg></div>
          <h3 data-i18n="features.9.title">Diagnostik Pintar</h3>
          <p data-i18n="features.9.p">Gunakan cek gejala terpandu, level risiko, aksi aman, dan catatan siap bengkel sebelum masalah membesar.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-amber"><svg><use href="#i-clipboard"/></svg></div>
          <h3 data-i18n="features.10.title">OCR Struk &amp; Odometer</h3>
          <p data-i18n="features.10.p">Scan struk servis atau odometer agar input lebih cepat dan catatan lebih rapi.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-purple"><svg><use href="#i-bell"/></svg></div>
          <h3 data-i18n="features.11.title">Laporan Mingguan &amp; Widget</h3>
          <p data-i18n="features.11.p">Lihat tren kesehatan kendaraan, reminder, aktivitas trip, dan ringkasan widget home screen.</p>
        </div>
        <div class="feature-card fade-up">
          <div class="feature-icon fi-cyan"><svg><use href="#i-car"/></svg></div>
          <h3 data-i18n="features.12.title">Bandingkan Kendaraan</h3>
          <p data-i18n="features.12.p">Bandingkan kendaraan di garasi memakai konteks health, odometer, trip, BBM, dan biaya servis.</p>
        </div>
      </div>
    </section>

    <!-- ===== HOW IT WORKS ===== -->
    <section class="how-it-works" id="how-it-works">
      <div class="section-header fade-up">
        <div class="section-badge" data-i18n="how.badge">Cara Kerja</div>
        <h2 data-i18n-html="how.h2">Mulai rapikan kendaraan<br>dalam hitungan menit.</h2>
        <p data-i18n="how.p">Mulai dengan login, tambah kendaraan, lalu rapikan riwayat servis dalam beberapa langkah.</p>
      </div>
      <div class="steps-grid">
        <div class="step-card fade-up">
          <div class="step-num">1</div>
          <h4 data-i18n="how.1.title">Tambah kendaraanmu</h4>
          <p data-i18n="how.1.p">Buat profil untuk mobil atau motormu dengan merek, model, tahun, dan plat nomor.</p>
        </div>
        <div class="step-card fade-up">
          <div class="step-num">2</div>
          <h4 data-i18n="how.2.title">Pantau kondisi</h4>
          <p data-i18n="how.2.p">Cek kilometer, kesehatan komponen, dan status perawatan dalam sekali lihat.</p>
        </div>
        <div class="step-card fade-up">
          <div class="step-num">3</div>
          <h4 data-i18n="how.3.title">Catat riwayat servis</h4>
          <p data-i18n="how.3.p">Simpan setiap perbaikan, servis, penggantian part, dan kunjungan bengkel beserta biaya dan tanggal.</p>
        </div>
        <div class="step-card fade-up">
          <div class="step-num">4</div>
          <h4 data-i18n="how.4.title">Rekam trip</h4>
          <p data-i18n="how.4.p">Lacak jarak, rute, dan aktivitas perjalanan dengan kontrol penuh atas data lokasi.</p>
        </div>
        <div class="step-card fade-up">
          <div class="step-num">5</div>
          <h4 data-i18n="how.5.title">Temukan bengkel</h4>
          <p data-i18n="how.5.p">Jelajahi bengkel terdekat dan pilih penyedia servis yang tepat untuk kendaraanmu.</p>
        </div>
        <div class="step-card fade-up">
          <div class="step-num">6</div>
          <h4 data-i18n="how.6.title">Backup dengan aman</h4>
          <p data-i18n="how.6.p">Jaga catatan tetap aman dengan backup terenkripsi dan cloud sync opsional untuk ketenangan pikiran.</p>
        </div>
      </div>
    </section>

    <!-- ===== PRIVACY & SECURITY ===== -->
    <section class="privacy" id="privacy">
      <div class="section-header fade-up">
        <div class="section-badge" data-i18n="privacy.badge">Privasi &amp; Keamanan</div>
        <h2 data-i18n="privacy.h2">Dibangun untuk privasi sejak awal.</h2>
      </div>
      <p class="privacy-intro fade-up" data-i18n-html="privacy.intro">
        Catatan kendaraan, riwayat servis, dan data trip kamu bersifat pribadi. <strong>SteerIn didesain dengan kontrol pengguna</strong>, penyimpanan local-first, backup terenkripsi opsional, dan tanpa tracker iklan.
      </p>
      <div class="privacy-grid">
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-phone"/></svg></div>
          <h4 data-i18n="privacy.1.title">Data lokal terlebih dahulu</h4>
          <p data-i18n="privacy.1.p">Semua data tersimpan di perangkat kamu secara default. Tidak ada server remote yang terlibat.</p>
        </div>
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-cloud"/></svg></div>
          <h4 data-i18n="privacy.2.title">Cloud sync opsional</h4>
          <p data-i18n="privacy.2.p">Sinkronisasi ke cloud hanya saat kamu putuskan. Tidak pernah otomatis atau dipaksa.</p>
        </div>
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-lock"/></svg></div>
          <h4 data-i18n="privacy.3.title">Backup terenkripsi</h4>
          <p data-i18n="privacy.3.p">Backup dilindungi enkripsi kuat sebelum keluar dari perangkat kamu.</p>
        </div>
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-pin"/></svg></div>
          <h4 data-i18n="privacy.4.title">GPS dikontrol pengguna</h4>
          <p data-i18n="privacy.4.p">Trip logging hanya berjalan saat kamu memulainya. Data lokasi tetap dalam kendalimu.</p>
        </div>
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-download"/></svg></div>
          <h4 data-i18n="privacy.5.title">Ekspor & hapus data</h4>
          <p data-i18n="privacy.5.p">Ekspor data kamu, hapus catatan lokal, atau bersihkan backup cloud kapan saja.</p>
        </div>
        <div class="privacy-card fade-up">
          <div class="privacy-card-icon"><svg><use href="#i-xcircle"/></svg></div>
          <h4 data-i18n="privacy.6.title">Tanpa iklan/tracker</h4>
          <p data-i18n="privacy.6.p">Tanpa SDK iklan, tanpa analitik, tanpa pelacakan pihak ketiga. Bersih dan privat.</p>
        </div>
      </div>
    </section>

