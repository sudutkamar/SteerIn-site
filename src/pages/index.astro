        <div class="faq-item fade-up">
          <button class="faq-q" aria-expanded="false" data-i18n="faq.6.q">Apakah aman install APK di luar Play Store?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
