---
const { links = [], ctaHref = '#download', ctaLabel = 'Download', ctaI18n = 'nav.download', showLanguage = false } = Astro.props;
---
<nav>
  <a href="/" class="nav-brand">
    <img src="/logo.png" alt="SteerIn" class="nav-logo">
    SteerIn
  </a>
  <div class="nav-links">
    {links.map(link => (
      <a href={link.href} class:list={[link.class, { active: link.active }]} data-i18n={link.i18n}>{link.label}</a>
    ))}
    <a href={ctaHref} class="nav-cta" data-i18n={ctaI18n}>{ctaLabel}</a>
    {showLanguage && (
      <div class="lang-switch" role="listbox" aria-label="Language">
        <button class="lang-btn" aria-haspopup="listbox" aria-expanded="false">
          <span class="lang-current">🇮🇩 ID</span>
          <svg class="lang-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="lang-dropdown">
          <button class="lang-option active" data-lang="id" role="option">🇮🇩 <span>Indonesia</span></button>
          <button class="lang-option" data-lang="en" role="option">🇬🇧 <span>English</span></button>
        </div>
      </div>
    )}
    <button class="theme-toggle" aria-label="Toggle theme">
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>
  </div>
  <div class="nav-controls">
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-sidebar">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>
