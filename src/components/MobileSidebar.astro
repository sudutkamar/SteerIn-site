---
const {
  links = [],
  ctaHref = '#download',
  ctaLabel = 'Download',
  ctaI18n = 'nav.download',
  showLanguage = false,
  eyebrow = 'Menu',
  description = 'Navigasi cepat SteerIn',
  descriptionI18n,
  eyebrowI18n,
} = Astro.props;

const icons = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  car: '<path d="M5 17h14M5 17a2 2 0 0 1-2-2v-4l2.5-5A2 2 0 0 1 7.5 5h9a2 2 0 0 1 2 2l2.5 5v4a2 2 0 0 1-2 2M5 17a2 2 0 1 0 4 0M19 17a2 2 0 1 0-4 0"/><circle cx="7" cy="15" r="1"/><circle cx="17" cy="15" r="1"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  help: '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  clipboard: '<rect x="8" y="2" width="8" height="4" rx="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><line x1="12" y1="11" x2="16" y2="11"/><line x1="12" y1="16" x2="16" y2="16"/><line x1="8" y1="11" x2="8" y2="11"/><line x1="8" y1="16" x2="8" y2="16"/>',
  download: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
};
---

<div class="nav-overlay" aria-hidden="true"></div>
<aside class="nav-sidebar" id="mobile-sidebar" aria-label="Menu navigasi" aria-hidden="true" tabindex="-1">
  <div class="sidebar-glow" aria-hidden="true"></div>
  <div class="sidebar-header">
    <a href="/" class="sidebar-brand">
      <img src="/logo.png" alt="SteerIn" class="nav-logo">
      <span>
        <strong>SteerIn</strong>
        <small data-i18n={eyebrowI18n}>{eyebrow}</small>
      </span>
    </a>
    <button class="sidebar-close" aria-label="Tutup menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <div class="sidebar-intro">
    <p data-i18n={descriptionI18n}>{description}</p>
    <div class="sidebar-pills" aria-label="Keunggulan singkat">
      <span data-i18n="sidebar.pill.privacy">Privat</span>
      <span data-i18n="sidebar.pill.local">Local-first</span>
      <span data-i18n="sidebar.pill.android">Android</span>
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Navigasi mobile">
    <span class="sidebar-section-label" data-i18n="sidebar.nav">Navigasi</span>
    {links.map(link => (
      <a href={link.href} class:list={[{ active: link.active }, link.class]}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[link.icon] || icons.car} />
        <span data-i18n={link.i18n}>{link.label}</span>
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-actions">
      <button class="theme-toggle sidebar-theme-toggle" aria-label="Toggle theme">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <span data-i18n="sidebar.theme">Tema</span>
      </button>
    </div>
    {showLanguage && (
      <div class="lang-switch lang-switch--stacked" role="listbox" aria-label="Language">
        <span class="sidebar-section-label sidebar-section-label--compact" data-i18n="sidebar.language">Bahasa</span>
        <div class="lang-dropdown">
          <button class="lang-option active" data-lang="id" role="option">🇮🇩 <span>Indonesia</span></button>
          <button class="lang-option" data-lang="en" role="option">🇬🇧 <span>English</span></button>
        </div>
      </div>
    )}
    <a href={ctaHref} class="nav-cta sidebar-cta" data-i18n={ctaI18n}>{ctaLabel}</a>
  </div>
</aside>
