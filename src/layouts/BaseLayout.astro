---
import '../style.css';

const {
  title = 'SteerIn — Garasi Digital Privat untuk Mobil & Motor',
  description = 'SteerIn adalah aplikasi Android privat untuk mengelola mobil dan motor, pengingat servis, riwayat perawatan, trip GPS, bengkel terdekat, dan kesehatan kendaraan dengan penyimpanan local-first.',
  canonical = 'https://steerin.app/',
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://steerin.app/logo.png',
  showCursor = false,
  showThree = false,
  orbs = 2,
  bodyClass = '',
} = Astro.props;
---
<!doctype html>
<html lang="id" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="robots" content="index, follow">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content={ogImage}>
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={ogDescription}>
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32">
  <link rel="icon" type="image/png" href="/favicon-48.png" sizes="48x48">
  <link rel="apple-touch-icon" href="/favicon-180.png">
  <link rel="manifest" href="/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <slot name="head" />
</head>
<body class={bodyClass}>
  {/* Loading screen only on home page */
  Astro.url.pathname === '/' && (
    <div id="loading-screen" aria-live="polite" aria-label="Memuat halaman">
      <div class="loading-inner">
        <div class="loading-logo-wrap">
          <div class="loading-glow"></div>
          <img src="/logo.png" alt="SteerIn" width="64" height="64" class="loading-logo" loading="eager" decoding="sync">
        </div>
        <span class="loading-brand">SteerIn</span>
        <div class="loading-bar-track">
          <div class="loading-bar-fill"></div>
        </div>
      </div>
    </div>
  )}

  <a href="#main" class="skip-link" data-i18n="skip">Lewati ke konten utama</a>
  <div class="noise"></div>
  {showCursor && <div id="cursor-glow" aria-hidden="true"></div>}
  {showThree && <div id="three-canvas" aria-hidden="true"></div>}
  {Array.from({ length: orbs }).map((_, i) => <div class={`orb orb--${i + 1}`}></div>)}
  <slot />

  <!-- Floating WhatsApp Bug Report Button -->
  <a href="https://wa.me/6281999701706?text=Halo%20SteerIn%2C%20saya%20ingin%20melaporkan%20bug%2Fmasalah%20di%20aplikasi%20SteerIn.%0A%0ADetail%3A%0A-%20Device%3A%0A-%20Android%20Version%3A%0A-%20SteerIn%20Version%3A%201.0%0A-%20Deskripsi%20bug%3A" class="wa-fab" target="_blank" rel="noopener noreferrer" aria-label="Laporkan bug via WhatsApp">
    <svg class="wa-fab-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span class="wa-fab-label" data-i18n="wa.fab.label">Laporkan Bug</span>
  </a>

  <script>import '../main.js';</script>
</body>
</html>
